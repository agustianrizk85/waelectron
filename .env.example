# Salin jadi `.env` lalu isi. Variabel dibaca saat `npm start`.

# --- PostgreSQL ---
# Kalau di-set, semua data app (master data, reminder, settings) disimpan di
# Postgres pada database `waelectron` (dibuat otomatis bila belum ada).
# Kalau dikosongkan, app fallback ke file JSON di folder userData.
# Ganti <password> dengan password user postgres kamu.
WA_DATABASE_URL=postgres://postgres:<password>@localhost:5432/waelectron?sslmode=disable

# --- Ollama (AI lokal "LaLa") ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:9b

# --- Chrome untuk WhatsApp (opsional) ---
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
